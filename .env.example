# =========================================
# ABA Bank - Environment Variables Example
# Copy this file to .env and fill in values
# =========================================

# --- Database ---
# Option A: PostgreSQL (recommended for production)
DATABASE_URL=postgresql://user:password@host:5432/ababank
# POSTGRES_URL=postgresql://user:password@host:5432/ababank

# Option B: SQLite (default for local dev - no config needed)
# SQLite database file: dev.db (auto-created)

# --- Authentication & Sessions ---
SESSION_SECRET=your-super-secret-session-key-min-32-chars

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/callback

# --- Gemini AI (optional) ---
GEMINI_API_KEY=your-gemini-api-key
VITE_GEMINI_API_KEY=your-gemini-api-key

# --- Vercel Blob Storage (for avatar uploads) ---
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx
ASSETS_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# --- WebAuthn / Passkey ---
RP_ID=localhost
RP_ORIGIN=http://localhost:3000
# For production:
# RP_ID=ababank-theta.vercel.app
# RP_ORIGIN=https://ababank-theta.vercel.app

# --- App Configuration ---
NODE_ENV=development
PORT=3000
VITE_API_URL=http://localhost:3000
